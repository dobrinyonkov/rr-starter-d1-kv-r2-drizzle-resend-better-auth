# Cloudflare D1 and KV are configured in wrangler.jsonc

# Better Auth secret — generate with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=change-me-to-a-random-secret

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Cloudflare Email Service — https://developers.cloudflare.com/email-routing/
# Must be a verified sender address in Cloudflare Email Routing
FROM_EMAIL=
